{
  "name": "@somnia/webapp",
  "version": "1.0.0",
  "packageManager": "pnpm@10.18.1",
  "scripts": {
    "dev": "expo start",
    "test": "jest",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "pnpm build:web",
    "build:web": "expo export --platform web --output-dir dist --clear && node ./scripts/postexport-web.cjs",
    "build:ios": "expo export --platform ios --output-dir dist-ios --clear",
    "build:android": "expo export --platform android --output-dir dist-android --clear",
    "build:web:debug": "EXPO_DEBUG=1 expo export --platform web --output-dir dist-debug --clear && WEB_DIST_DIR=dist-debug node ./scripts/postexport-web.cjs",
    "types": "tsc --noEmit --project ./tsconfig.json",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/.eslintcache \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@react-native-cookies/cookies": "github:react-native-cookies/cookies",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/elements": "^1.3.31",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@sentry/react": "^10.42.0",
    "@somnia/shared": "workspace:*",
    "@tanstack/react-query": "^5.90.3",
    "@trpc/client": "^11.6.0",
    "@trpc/react-query": "^11.6.0",
    "@trpc/server": "^11.7.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.12",
    "expo-font": "^14.0.9",
    "expo-image-picker": "~17.0.10",
    "expo-secure-store": "^15.0.7",
    "expo-status-bar": "~3.0.8",
    "lodash": "^4.17.21",
    "mixpanel-browser": "^2.77.0",
    "pretty-format": "29.7.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.4",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "^4.1.3",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "^4.16.0",
    "react-native-web": "^0.21.0",
    "superjson": "^2.2.5",
    "zod": "^4.1.12",
    "zod-formik-adapter": "^2.0.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.20",
    "@types/mixpanel-browser": "^2.66.0",
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
