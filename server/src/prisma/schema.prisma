generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id                     String                  @id @default(uuid())
    nickname               String                  @unique
    email                  String                  @unique
    name                   String                  @default("")
    password               String
    avatar                 String?
    createdAt              DateTime                @default(now())
    posts                  Post[]
    comments               Comment[]
    postLikes              PostLike[]
    sentNotifications      Notification[]          @relation("NotificationActor")
    receivedNotifications  Notification[]          @relation("NotificationRecipient")
    permissions            UserPermission[]
    ownedCommunities       Community[]             @relation("CommunityOwner")
    communityMemberships   CommunityMember[]
    communitySubscriptions CommunitySubscription[]
    communityBlacklistEntries    CommunityBlacklist[] @relation("CommunityBlacklistUser")
    createdCommunityBlacklistEntries CommunityBlacklist[] @relation("CommunityBlacklistCreator")
    communityActionLogsAsActor   CommunityActionLog[] @relation("CommunityActionActor")
    communityActionLogsAsTarget  CommunityActionLog[] @relation("CommunityActionTarget")
    blockedUsers                 UserBlockedUser[]     @relation("UserBlockedUsers")
    blockedByUsers               UserBlockedUser[]     @relation("BlockedByUsers")
    blockedCommunities           UserBlockedCommunity[]
    createdReports               Report[]              @relation("ReportReporter")
    reportsAboutUser             Report[]              @relation("ReportTargetUser")
    handledReports               Report[]              @relation("ReportHandler")
    followers              UserFollow[]            @relation("UserFollowers")
    following              UserFollow[]            @relation("UserFollowing")
}

enum UserPermission {
    DELETE_POST
    ALL
}

model Post {
    id                   String            @id @default(uuid())
    seq                  Int               @unique @default(autoincrement())
    title                String
    description          String
    text                 String
    images               String[]
    createdAt            DateTime          @default(now())
    authorId             String
    author               User              @relation(fields: [authorId], references: [id])
    publisherType        PostPublisherType @default(USER)
    publisherCommunityId String?
    publisherCommunity   Community?        @relation("CommunityPosts", fields: [publisherCommunityId], references: [id], onDelete: SetNull)
    comments             Comment[]
    postLikes            PostLike[]
    notifications        Notification[]
    communityActionLogs  CommunityActionLog[]
    reports              Report[]
    deletedAt            DateTime?

    @@index([publisherType, seq])
    @@index([publisherCommunityId])
}

enum PostPublisherType {
    USER
    COMMUNITY
}

model Community {
    id            String                  @id @default(uuid())
    name          String                  @unique
    description   String                  @default("")
    avatar        String?
    createdAt     DateTime                @default(now())
    ownerId       String
    owner         User                    @relation("CommunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
    members       CommunityMember[]
    subscriptions CommunitySubscription[]
    posts         Post[]                  @relation("CommunityPosts")
    blacklistEntries CommunityBlacklist[]
    actionLogs      CommunityActionLog[]
    notifications   Notification[]
    blockedByUsers  UserBlockedCommunity[]
}

enum CommunityMemberRole {
    OWNER
    MODERATOR
    MEMBER
}

model CommunityMember {
    id          String              @id @default(uuid())
    createdAt   DateTime            @default(now())
    updatedAt   DateTime            @updatedAt
    role        CommunityMemberRole
    userId      String
    communityId String
    user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
    community   Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)

    @@unique([communityId, userId])
    @@index([userId])
    @@index([communityId, role])
}

model CommunitySubscription {
    id          String    @id @default(uuid())
    createdAt   DateTime  @default(now())
    userId      String
    communityId String
    user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

    @@unique([communityId, userId])
    @@index([userId, createdAt])
    @@index([communityId])
}

model CommunityBlacklist {
    id              String    @id @default(uuid())
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt
    expiresAt       DateTime?
    unblockedNotifiedAt DateTime?
    restoreSubscriptionOnUnblock Boolean @default(false)
    communityId     String
    userId          String
    createdByUserId String
    community       Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
    user            User      @relation("CommunityBlacklistUser", fields: [userId], references: [id], onDelete: Cascade)
    createdBy       User      @relation("CommunityBlacklistCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

    @@unique([communityId, userId])
    @@index([communityId, createdAt])
    @@index([userId, expiresAt])
}

enum CommunityActionType {
    BLACKLIST_ADDED
    BLACKLIST_REMOVED
    MODERATOR_ASSIGNED
    MODERATOR_REVOKED
    OWNERSHIP_TRANSFERRED
    POST_PUBLISHED
    POST_UPDATED
    POST_DELETED
    COMMUNITY_UPDATED
    COMMUNITY_AVATAR_UPDATED
}

model CommunityActionLog {
    id           String              @id @default(uuid())
    createdAt    DateTime            @default(now())
    actionType   CommunityActionType
    details      Json?
    communityId  String
    actorUserId  String?
    targetUserId String?
    postId       String?
    community    Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)
    actor        User?               @relation("CommunityActionActor", fields: [actorUserId], references: [id], onDelete: SetNull)
    targetUser   User?               @relation("CommunityActionTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
    post         Post?               @relation(fields: [postId], references: [id], onDelete: SetNull)

    @@index([communityId, createdAt])
    @@index([actorUserId, createdAt])
    @@index([targetUserId, createdAt])
}

model UserBlockedUser {
    id            String   @id @default(uuid())
    createdAt     DateTime @default(now())
    userId        String
    blockedUserId String
    user          User     @relation("UserBlockedUsers", fields: [userId], references: [id], onDelete: Cascade)
    blockedUser   User     @relation("BlockedByUsers", fields: [blockedUserId], references: [id], onDelete: Cascade)

    @@unique([userId, blockedUserId])
    @@index([userId, createdAt])
    @@index([blockedUserId, createdAt])
}

model UserBlockedCommunity {
    id          String    @id @default(uuid())
    createdAt   DateTime  @default(now())
    userId      String
    communityId String
    user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

    @@unique([userId, communityId])
    @@index([userId, createdAt])
    @@index([communityId, createdAt])
}

enum ReportTargetType {
    POST
    USER
}

enum ReportStatus {
    OPEN
    IN_REVIEW
    RESOLVED
    REJECTED
}

model Report {
    id            String           @id @default(uuid())
    createdAt     DateTime         @default(now())
    updatedAt     DateTime         @updatedAt
    description   String
    targetType    ReportTargetType
    status        ReportStatus     @default(OPEN)
    reporterUserId String
    postId        String?
    targetUserId  String?
    handledByUserId String?
    handledAt     DateTime?
    resolutionNote String?
    reporter      User             @relation("ReportReporter", fields: [reporterUserId], references: [id], onDelete: Cascade)
    post          Post?            @relation(fields: [postId], references: [id], onDelete: SetNull)
    targetUser    User?            @relation("ReportTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
    handledBy     User?            @relation("ReportHandler", fields: [handledByUserId], references: [id], onDelete: SetNull)

    @@index([status, createdAt])
    @@index([reporterUserId, createdAt])
    @@index([reporterUserId, targetType, status, createdAt])
    @@index([reporterUserId, postId, status, createdAt])
    @@index([reporterUserId, targetUserId, status, createdAt])
    @@index([postId, createdAt])
    @@index([targetUserId, createdAt])
}

model UserFollow {
    id          String   @id @default(uuid())
    seq         Int      @unique @default(autoincrement())
    createdAt   DateTime @default(now())
    followerId  String
    followingId String
    follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
    following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

    @@unique([followerId, followingId])
    @@index([followerId, seq])
    @@index([followingId, seq])
}

model PostLike {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now())
    post      Post     @relation(fields: [postId], references: [id])
    postId    String
    user      User     @relation(fields: [userId], references: [id])
    userId    String

    @@unique([postId, userId])
}

model Comment {
    id      String @id @default(uuid())
    content String

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    deletedAt DateTime?

    postId String
    post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

    authorId String
    author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

    parentId      String?
    parent        Comment?       @relation("CommentTree", fields: [parentId], references: [id])
    replies       Comment[]      @relation("CommentTree")
    notifications Notification[]

    @@index([postId])
    @@index([authorId])
    @@index([parentId])
}

enum NotificationType {
    POST_LIKED
    POST_COMMENTED
    COMMENT_REPLIED
    USER_FOLLOWED
    COMMUNITY_BLACKLISTED
    COMMUNITY_UNBLACKLISTED
}

model Notification {
    id        String           @id @default(uuid())
    type      NotificationType
    createdAt DateTime         @default(now())
    readAt    DateTime?
    details   Json?

    recipientId String
    recipient   User   @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

    actorId String
    actor   User   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)

    postId String?
    post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)

    commentId String?
    comment   Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)
    communityId String?
    community   Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)

    @@index([recipientId, createdAt])
    @@index([actorId, createdAt])
    @@index([postId])
    @@index([commentId])
    @@index([communityId])
}
