{
  "name": "somnia",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.18.1",
  "scripts": {
    "b": "pnpm --filter @somnia/server",
    "f": "pnpm --filter @somnia/webapp",
    "build:server": "pnpm --filter @somnia/server build",
    "start:server": "pnpm --filter @somnia/server start",
    "types": " concurrently 'pnpm b types && pnpm f types'",
    "lint": "concurrently 'pnpm b lint && pnpm f lint'",
    "prettify": "pnpm -r exec prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css,scss,html}\"",
    "prepare": "husky",
    "docker:build:server": "docker build -f server/Dockerfile -t somnia-server:local .",
    "docker:run:server": "docker run --rm -p 3000:3000 --env-file server/.env -e DATABASE_URL=\"postgresql://somnia:somnia@host.docker.internal:5432/somnia?schema=public\" somnia-server:local", 
    "docker:build:webapp": "sh ./scripts/docker-build-webapp.sh",
    "docker:build:web": "pnpm docker:build:webapp",
    "docker:run:webapp": "docker run --rm -p 8081:80 somnia-webapp:local"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.2.4",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.6"
  }
}
